<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1"
>
    <display-name>Artportfolio</display-name>
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.iacademy.cselec05.servlet.auth.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>LandingServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.servlet.views.LandingServlet</servlet-class>
    </servlet>
    <!-- changed "/" to "/landing" -->
    <!-- Changed it to /landing - Juan Amado Cleto
        Issues: if it is "/" - style.css will redirected and thus will not reflect on
        the pages thus we need to change it to landing page
    -->
    <servlet-mapping>
        <servlet-name>LandingServlet</servlet-name>
        <url-pattern>/landing</url-pattern> <!-- this is what screwed the css and js by having just "/" -->
    </servlet-mapping>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.servlet.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Register -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.servlet.auth.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Home -->
    <!-- This is an interesting scenario because we have two homefeed jsps
        What I ought to do like Lenin is merge the home jsp and homefeed jsp.

        Again like the two database connections - we dont want two database connections,
        therefore centralized.
    -->
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.servlet.profile.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <!-- Profile -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.servlet.profile.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>

    <!-- Settings -->
    <servlet>
        <servlet-name>SettingsServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.servlet.profile.SettingsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SettingsServlet</servlet-name>
        <url-pattern>/settings</url-pattern>
    </servlet-mapping>

    <!-- Logout -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.servlet.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- User Activity Servlet -->
    <servlet>
        <servlet-name>UserActivityServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.userActivities.UserActivityServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserActivityServlet</servlet-name>
        <url-pattern>/profile/user-activity</url-pattern>
    </servlet-mapping>

    <!-- Insert Picture Servlet -->
    <servlet>
        <servlet-name>InsertPictureServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.userActivities.InsertPictureServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InsertPictureServlet</servlet-name>
        <url-pattern>/profile/user-activity/upload-art</url-pattern>
    </servlet-mapping>

    <!-- deprecated Servlet -->
    <servlet>
        <servlet-name>InsertServlet</servlet-name>
        <servlet-class>com.iacademy.cselec05.userActivities.InsertServlet</servlet-class>
    </servlet>
    <!-- Insert jsp will appear here served by MyServlet - though this should be renamed to something else
        Done - Juan Amado Cleto
    -->
    <servlet-mapping>
        <servlet-name>InsertServlet</servlet-name>
        <url-pattern>/profile/user-activity/insert</url-pattern>
    </servlet-mapping>

</web-app>